# Proprietary strategy source and derivative artifacts. Default-deny this
# folder; allow only the public package marker, sample scaffold, and demo
# strategy explicitly.
strategies/**
!strategies/
!strategies/__init__.py
!strategies/_sample_strategy.py
!strategies/stoch_3m_cross_long.py

# Internal strategy documentation/tests can reveal IDs, instruments,
# thresholds, scoring formulas, exits, or adopted-position ownership.
# `docs/roadmap/` is the local backlog/review/deferred-work area and remains
# ignored unless a note is deliberately sanitized for public docs.
*.md
!README.md
docs/**
!docs/
!docs/guardrails.md
!docs/project_rules.md
tests/**
!tests/
!tests/**/
!tests/**/__init__.py
configs/**
config.local*
config.private*
config.proprietary*
*.local.yaml
*.local.yml
*.private.yaml
*.private.yml
*.proprietary.yaml
*.proprietary.yml

# Generic private-artifact catchalls. Avoid strategy-specific names here:
# the ignore file itself is public.
*private*
*proprietary*
*internal*
*secret*
*research*
*experiment*
*sweep*
*walk_forward*
*backtest_run*
*decision*
*signal*
*order*
*fill*

# Legacy/research material often contains the original strategy formulas.
legacy/
archived/
archive/
research/
research*/
experiments/
experiments*/
sweeps/
sweeps*/
notebooks/
*.ipynb

